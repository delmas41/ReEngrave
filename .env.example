# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Database
DATABASE_URL=sqlite+aiosqlite:///./reengrave.db

# Storage
UPLOAD_DIR=./uploads
EXPORT_DIR=./exports

# Audiveris
AUDIVERIS_HOME=/opt/Audiveris

# Auth (JWT)
SECRET_KEY=change-me-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
# Comma-separated admin emails — these users get full access with no payment required
ADMIN_EMAILS=delmas41@gmail.com

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# CORS / Frontend
# Comma-separated list of allowed origins for the API
CORS_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Frontend (Vite)
VITE_API_URL=http://localhost:8000

# Railway
RAILWAY_TOKEN=...

# Vercel
VERCEL_TOKEN=...
VERCEL_ORG_ID=...
VERCEL_PROJECT_ID=...
