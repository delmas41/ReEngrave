# Copy this file to .env and fill in your values.
# .env is gitignored — never commit actual secrets.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./reengrave.db

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme-replace-with-64-char-random-string

# Comma-separated list of email addresses that bypass all payment gates
ADMIN_EMAILS=you@example.com

# ── Anthropic / Claude ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Stripe ────────────────────────────────────────────────────────────────────
# Leave blank until you have Stripe set up.
# Without these, Vision AI is restricted to ADMIN_EMAILS only.
# Non-admins will see a "coming soon" paywall but cannot access Vision AI.
# Fill these in when you're ready to open payments to users.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# ── File storage ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
EXPORT_DIR=./exports

# ── CORS / Frontend URL ───────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173
