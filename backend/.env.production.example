# ReEngrave — Production environment variables
# Copy to .env.production and fill in all values before deploying.
# NEVER commit .env.production to git.

# ---------------------------------------------------------------------------
# Database (set automatically by docker-compose.prod.yml — do not change)
# ---------------------------------------------------------------------------
# DATABASE_URL=sqlite+aiosqlite:////app/data/reengrave.db

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_64_CHAR_HEX_SECRET

# ---------------------------------------------------------------------------
# Admin access
# ---------------------------------------------------------------------------
# Comma-separated list of email addresses that bypass the payment gate
ADMIN_EMAILS=you@yourdomain.com

# ---------------------------------------------------------------------------
# Anthropic (Claude Vision)
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-...

# ---------------------------------------------------------------------------
# Stripe (payments)
# Get keys from https://dashboard.stripe.com/apikeys
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
# Create a product + price at https://dashboard.stripe.com/products
STRIPE_PRICE_ID=price_...
# Get from https://dashboard.stripe.com/webhooks (add endpoint: https://DOMAIN/api/payments/webhook)
STRIPE_WEBHOOK_SECRET=whsec_...

# ---------------------------------------------------------------------------
# App URLs — update to your real domain
# ---------------------------------------------------------------------------
CORS_ORIGINS=https://yourdomain.com
FRONTEND_URL=https://yourdomain.com

# ---------------------------------------------------------------------------
# File paths (set by docker-compose — do not change)
# ---------------------------------------------------------------------------
UPLOAD_DIR=/app/uploads
EXPORT_DIR=/app/exports

# ---------------------------------------------------------------------------
# Session
# ---------------------------------------------------------------------------
ACCESS_TOKEN_EXPIRE_MINUTES=480
